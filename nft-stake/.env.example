# Admin deployer wallet. Never commit a real private key.
PRIVATE_KEY=

# RPC endpoints
SEPOLIA_RPC_URL=
BSC_TESTNET_RPC_URL=
BSC_RPC_URL=

# Existing payment token.
# Leave empty on local/testnet if you want scripts/deploy.ts to deploy MockUSDT.
# Required on BSC mainnet.
USDT_ADDRESS=

# Project wallets. If empty, deploy script uses the deployer wallet.
TREASURY_ADDRESS=
AIRDROP_ADDRESS=

# NFT image/metadata base used by the frontend presentation flow.
BASE_URI=https://api.dicebear.com/9.x/adventurer/svg?seed=metacrown-

# Optional frontend override values printed by deploy.ts.
FRONTEND_RPC_URL=
FRONTEND_BLOCK_EXPLORER=

# Block explorer verification
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=

# Admin mint script options
STAKE_ECOSYSTEM_ADDRESS=
NFT_COUNT=100
# PACKAGE_ID=1 # optional: 1 Silver, 2 Gold, 3 Diamond. Empty = round-robin.
